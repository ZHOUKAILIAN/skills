# Customer Service Troubleshoot Skill - Environment Configuration
# Copy this file to config.env and fill in the actual values

# Git Repository URL
CST_GIT_REPO="git@your-gitlab.com/your-org/your-repo.git"

# Log access method and connection details
# Fill in the variables needed by the log system the user actually uses
CST_LOG_ACCESS_METHOD="aliyun-cli"
# CST_LOG_ENDPOINT="https://your-log-endpoint"
# CST_LOG_PROJECT="your-log-project"
# CST_LOG_STORE="your-logstore"
# CST_LOG_CLUSTER="your-cluster-context"
# CST_LOG_NAMESPACE="your-namespace"
# CST_LOG_TOKEN="your-log-token"

# Optional: aliyun-cli credentials
# Only needed if the user chooses aliyun-cli for log queries
ALIBABA_CLOUD_ACCESS_KEY_ID="your-access-key-id"
ALIBABA_CLOUD_ACCESS_KEY_SECRET="your-access-key-secret"
ALIBABA_CLOUD_REGION_ID="cn-hangzhou"
# Optional: only needed if using temporary STS credentials
# ALIBABA_CLOUD_SECURITY_TOKEN="your-security-token"

# MySQL Database (read-only access)
CST_MYSQL_HOST="your-mysql-host.rwlb.rds.aliyuncs.com"
CST_MYSQL_PORT="3306"
CST_MYSQL_USER="readonly_user"
CST_MYSQL_PASSWORD="YOUR_PASSWORD_HERE"
